DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinellm
REDIS_URL=redis://localhost:6379/0
SENTINEL_CONFIG_PATH=config.yaml
SENTINEL_ENV=development

# Security — set in production
# SENTINEL_API_KEY=your-secret-api-key  # enforces X-API-Key on all requests when set
# SENTINEL_CORS_ORIGINS=https://your-dashboard.example.com  # comma-separated allowed origins

# Cloud LLM providers — set only the one matching llm_backend.provider in config.yaml
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
