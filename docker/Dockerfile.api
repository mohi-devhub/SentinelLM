FROM python:3.11-slim

WORKDIR /app

# System dependencies required by spaCy and Presidio
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies first (layer cache: only re-runs if requirements change)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Download spaCy model required by Presidio — must run after pip install
RUN python -m spacy download en_core_web_lg

# Copy application source
COPY . .

EXPOSE 8000

CMD ["uvicorn", "sentinel.main:app", "--host", "0.0.0.0", "--port", "8000"]
