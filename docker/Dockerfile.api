FROM python:3.11-slim

# Create non-root user for production security
RUN groupadd --gid 1001 sentinel && \
    useradd --uid 1001 --gid sentinel --shell /bin/bash --create-home sentinel

WORKDIR /app

# System dependencies required by spaCy and Presidio
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install CPU-only PyTorch before the rest of requirements.txt.
# The default pip index serves the CUDA build on Linux (~2.5 GB); the CPU build
# is ~900 MB.  pip treats torch==2.4.1+cpu as satisfying the torch==2.4.1
# constraint in requirements.txt so it will not be reinstalled.
RUN pip install --no-cache-dir \
    torch==2.4.1 \
    --index-url https://download.pytorch.org/whl/cpu

# Install remaining Python dependencies (torch is already satisfied above)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Download spaCy NER model for PII detection.
# en_core_web_sm (~12 MB) is sufficient for production; swap to en_core_web_lg
# (~700 MB) if you need higher PII recall on dense free-text.
RUN python -m spacy download en_core_web_sm

# Copy application source and fix ownership
COPY --chown=sentinel:sentinel . .

# Switch to non-root user
USER sentinel

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uvicorn", "sentinel.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
